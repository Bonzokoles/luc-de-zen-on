---
import MainLayout from "../layouts/MainLayout.astro";
import BalloonLibrary from "../components/animations/BalloonLibrary";
import { SparkleEffect } from "../components/animations/BalloonLibrary";
import NewsBiznesowe from "../components/shared/NewsBiznesowe";
import MusicPlayerVisualizer from "../components/shared/MusicPlayerVisualizer";
---

<MainLayout
  title="ZENON_Biznes_HUB – Centrum Zarządzania Biznesem"
  description="ZENON_Biznes_HUB – inteligentna platforma biznesowa: ERP, AI Assistant, Workflow Builder, Magazyn, Finanse i więcej."
>
  <BalloonLibrary client:load count={12} speed="slow" />
  <SparkleEffect client:load density={10} />

  <!-- ===== HERO ===== -->
  <section
    class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden px-4 pt-10 pb-20"
  >
    <!-- Radial glow orbs -->
    <div
      class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full pointer-events-none z-0"
      style="background: radial-gradient(circle, rgba(0,217,255,0.08) 0%, transparent 70%);"
    >
    </div>
    <div
      class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full pointer-events-none z-0"
      style="background: radial-gradient(circle, rgba(74,222,128,0.06) 0%, transparent 70%);"
    >
    </div>

    <div class="relative z-10 text-center max-w-5xl mx-auto">
      <!-- Logo -->
      <div class="flex justify-center mb-8 hero-logo">
        <div class="relative w-24 h-24 md:w-32 md:h-32 animate-float">
          <div
            class="absolute inset-0 bg-gradient-to-br from-business-accent/40 to-business-accent-soft/30 blur-2xl animate-pulse rounded-full"
          >
          </div>
          <img
            src="/apple-touch-icon.png"
            alt="ZENON Biznes HUB"
            class="relative w-full h-full object-contain drop-shadow-[0_0_30px_rgba(0,217,255,0.7)]"
          />
        </div>
      </div>

      <!-- Title -->
      <h1 class="text-5xl md:text-7xl font-bold mb-4 hero-title leading-tight">
        <span
          style="-webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; background-image: linear-gradient(to right, #00d9ff, #38bdf8, #4ade80);"
        >
          ZENON
        </span>
        <span class="text-business-text">_Biznes_</span>
        <span
          style="-webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; background-image: linear-gradient(to right, #4ade80, #38bdf8, #00d9ff);"
        >
          HUB
        </span>
      </h1>

      <!-- Tagline -->
      <p
        class="text-xl md:text-2xl text-business-text-dim mb-4 hero-sub font-light tracking-wide"
      >
        Inteligentna platforma zarządzania biznesem
      </p>
      <p
        class="text-base md:text-lg text-business-text-dim/70 mb-12 max-w-2xl mx-auto hero-desc"
      >
        ERP &middot; AI Asystent &middot; Workflow Builder &middot; Magazyn
        &middot; Finanse &middot; CRM &middot; Analityka
      </p>

      <!-- CTA Buttons -->
      <div
        class="flex flex-col sm:flex-row gap-4 justify-center mb-16 hero-cta"
      >
        <a
          href="/ai-biznes-erp"
          class="group relative inline-flex items-center gap-3 px-8 py-4 rounded-xl font-semibold text-lg overflow-hidden transition-all duration-300"
          style="background: linear-gradient(135deg, rgba(0,217,255,0.15), rgba(14,165,233,0.15)); border: 1px solid rgba(0,217,255,0.4); box-shadow: 0 0 20px rgba(0,217,255,0.15);"
        >
          <span
            class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
            style="background: linear-gradient(135deg, rgba(0,217,255,0.25), rgba(14,165,233,0.25));"
          ></span>
          <svg
            class="relative w-5 h-5 text-business-accent"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
            ></path>
          </svg>
          <span class="relative text-business-accent">Otwórz ERP</span>
        </a>

        <a
          href="/asystent-ai"
          class="group relative inline-flex items-center gap-3 px-8 py-4 rounded-xl font-semibold text-lg overflow-hidden transition-all duration-300"
          style="background: linear-gradient(135deg, rgba(74,222,128,0.10), rgba(16,185,129,0.10)); border: 1px solid rgba(74,222,128,0.35); box-shadow: 0 0 20px rgba(74,222,128,0.10);"
        >
          <span
            class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
            style="background: linear-gradient(135deg, rgba(74,222,128,0.2), rgba(16,185,129,0.2));"
          ></span>
          <svg
            class="relative w-5 h-5 text-business-accent-soft"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
            ></path>
          </svg>
          <span class="relative text-business-accent-soft">AI Asystent</span>
        </a>

        <a
          href="/unified-ops"
          class="group relative inline-flex items-center gap-3 px-8 py-4 rounded-xl font-semibold text-lg overflow-hidden transition-all duration-300"
          style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1);"
        >
          <span
            class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
            style="background: rgba(255,255,255,0.06);"></span>
          <svg
            class="relative w-5 h-5 text-business-text-dim"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          <span class="relative text-business-text-dim">Workflow</span>
        </a>
      </div>

      <!-- Stats Bar -->
      <div
        class="grid grid-cols-2 md:grid-cols-4 gap-px hero-stats overflow-hidden rounded-2xl"
        style="background: rgba(0,217,255,0.1); border: 1px solid rgba(0,217,255,0.15);"
      >
        <div
          class="flex flex-col items-center py-5 px-4"
          style="background: rgba(0,0,0,0.6);"
        >
          <span
            class="text-3xl font-bold bg-gradient-to-r from-business-accent to-primary-400 bg-clip-text text-transparent"
            >8+</span
          >
          <span
            class="text-xs text-business-text-dim mt-1 tracking-wider uppercase"
            >Modułów</span
          >
        </div>
        <div
          class="flex flex-col items-center py-5 px-4"
          style="background: rgba(0,0,0,0.6);"
        >
          <span
            class="text-3xl font-bold bg-gradient-to-r from-business-accent-soft to-primary-400 bg-clip-text text-transparent"
            >AI</span
          >
          <span
            class="text-xs text-business-text-dim mt-1 tracking-wider uppercase"
            >Asystent</span
          >
        </div>
        <div
          class="flex flex-col items-center py-5 px-4"
          style="background: rgba(0,0,0,0.6);"
        >
          <span
            class="text-3xl font-bold bg-gradient-to-r from-purple-400 to-business-accent bg-clip-text text-transparent"
            >∞</span
          >
          <span
            class="text-xs text-business-text-dim mt-1 tracking-wider uppercase"
            >Workflow</span
          >
        </div>
        <div
          class="flex flex-col items-center py-5 px-4"
          style="background: rgba(0,0,0,0.6);"
        >
          <span
            class="text-3xl font-bold bg-gradient-to-r from-business-warning to-business-accent-soft bg-clip-text text-transparent"
            >PL</span
          >
          <span
            class="text-xs text-business-text-dim mt-1 tracking-wider uppercase"
            >Interfejs</span
          >
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div
      class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-50 animate-bounce"
    >
      <span class="text-xs text-business-text-dim tracking-widest uppercase"
        >Przewiń</span
      >
      <svg
        class="w-5 h-5 text-business-accent"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 9l-7 7-7-7"></path>
      </svg>
    </div>
  </section>

  <!-- ===== MODULES GRID ===== -->
  <section class="relative z-10 py-20 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-14">
        <span
          class="inline-block text-xs font-semibold tracking-[0.25em] uppercase text-business-accent mb-4 px-4 py-1.5 rounded-full"
          style="background: rgba(0,217,255,0.08); border: 1px solid rgba(0,217,255,0.2);"
          >Platforma</span
        >
        <h2 class="text-4xl md:text-5xl font-bold text-business-text mb-4">
          Wszystko czego potrzebujesz<br />
          <span
            class="bg-gradient-to-r from-business-accent to-business-accent-soft bg-clip-text text-transparent"
            >w jednym miejscu</span
          >
        </h2>
        <p class="text-business-text-dim text-lg max-w-2xl mx-auto">
          Kompletny ekosystem narzędzi biznesowych zaprojektowanych dla
          nowoczesnych przedsiębiorstw.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <!-- ERP -->
        <a
          href="/ai-biznes-erp"
          class="module-card group relative overflow-hidden rounded-2xl p-6 transition-all duration-300 cursor-pointer"
          style="background: rgba(10,10,10,0.8); border: 1px solid rgba(255,255,255,0.06);"
        >
          <div
            class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            style="background: linear-gradient(135deg, rgba(0,217,255,0.05) 0%, transparent 60%);"
          >
          </div>
          <div
            class="absolute top-0 left-0 right-0 h-px opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            style="background: linear-gradient(90deg, transparent, rgba(0,217,255,0.6), transparent);"
          >
          </div>
          <div class="relative">
            <div
              class="w-12 h-12 rounded-xl mb-5 flex items-center justify-center"
              style="background: linear-gradient(135deg, rgba(0,217,255,0.15), rgba(14,165,233,0.1)); border: 1px solid rgba(0,217,255,0.2);"
            >
              <svg
                class="w-6 h-6 text-business-accent"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
                ></path>
              </svg>
            </div>
            <h3
              class="text-lg font-semibold text-business-text mb-2 group-hover:text-business-accent transition-colors"
            >
              AI Biznes ERP
            </h3>
            <p class="text-sm text-business-text-dim leading-relaxed">
              Kompleksowy system ERP z fakturami VAT, magazynem i generatorem
              treści. Zarządzaj całym biznesem z jednego miejsca.
            </p>
            <div
              class="mt-4 flex items-center gap-1.5 text-xs text-business-accent opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-2 group-hover:translate-x-0"
            >
              <span>Otwórz moduł</span>
              <svg
                class="w-3.5 h-3.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </div>
        </a>

        <!-- AI Asystent -->
        <a
          href="/asystent-ai"
          class="module-card group relative overflow-hidden rounded-2xl p-6 transition-all duration-300 cursor-pointer"
          style="background: rgba(10,10,10,0.8); border: 1px solid rgba(255,255,255,0.06);"
        >
          <div
            class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            style="background: linear-gradient(135deg, rgba(74,222,128,0.05) 0%, transparent 60%);"
          >
          </div>
          <div
            class="absolute top-0 left-0 right-0 h-px opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            style="background: linear-gradient(90deg, transparent, rgba(74,222,128,0.6), transparent);"
          >
          </div>
          <div class="relative">
            <div
              class="w-12 h-12 rounded-xl mb-5 flex items-center justify-center"
              style="background: linear-gradient(135deg, rgba(74,222,128,0.15), rgba(16,185,129,0.1)); border: 1px solid rgba(74,222,128,0.2);"
            >
              <svg
                class="w-6 h-6 text-business-accent-soft"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
                ></path>
              </svg>
            </div>
            <h3
              class="text-lg font-semibold text-business-text mb-2 group-hover:text-business-accent-soft transition-colors"
            >
              AI Asystent
            </h3>
            <p class="text-sm text-business-text-dim leading-relaxed">
              Inteligentny asystent biznesowy zasilany przez AI. Analizuje dane,
              odpowiada na pytania i pomaga w podejmowaniu decyzji.
            </p>
            <div
              class="mt-4 flex items-center gap-1.5 text-xs text-business-accent-soft opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-2 group-hover:translate-x-0"
            >
              <span>Otwórz moduł</span>
              <svg
                class="w-3.5 h-3.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </div>
        </a>

        <!-- Workflow Builder -->
        <a
          href="/unified-ops"
          class="module-card group relative overflow-hidden rounded-2xl p-6 transition-all duration-300 cursor-pointer"
          style="background: rgba(10,10,10,0.8); border: 1px solid rgba(255,255,255,0.06);"
        >
          <div
            class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            style="background: linear-gradient(135deg, rgba(167,139,250,0.05) 0%, transparent 60%);"
          >
          </div>
          <div
            class="absolute top-0 left-0 right-0 h-px opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            style="background: linear-gradient(90deg, transparent, rgba(167,139,250,0.6), transparent);"
          >
          </div>
          <div class="relative">
            <div
              class="w-12 h-12 rounded-xl mb-5 flex items-center justify-center"
              style="background: linear-gradient(135deg, rgba(167,139,250,0.15), rgba(139,92,246,0.1)); border: 1px solid rgba(167,139,250,0.2);"
            >
              <svg
                class="w-6 h-6 text-purple-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3
              class="text-lg font-semibold text-business-text mb-2 group-hover:text-purple-400 transition-colors"
            >
              Unified Ops
            </h3>
            <p class="text-sm text-business-text-dim leading-relaxed">
              Wizualny builder workflow. Twórz automatyzacje procesów
              biznesowych metodą drag-and-drop bez pisania kodu.
            </p>
            <div
              class="mt-4 flex items-center gap-1.5 text-xs text-purple-400 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-2 group-hover:translate-x-0"
            >
              <span>Otwórz moduł</span>
              <svg
                class="w-3.5 h-3.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </div>
        </a>

        <!-- Magazyn -->
        <a
          href="/magazyn"
          class="module-card group relative overflow-hidden rounded-2xl p-6 transition-all duration-300 cursor-pointer"
          style="background: rgba(10,10,10,0.8); border: 1px solid rgba(255,255,255,0.06);"
        >
          <div
            class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            style="background: linear-gradient(135deg, rgba(251,191,36,0.05) 0%, transparent 60%);"
          >
          </div>
          <div
            class="absolute top-0 left-0 right-0 h-px opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            style="background: linear-gradient(90deg, transparent, rgba(251,191,36,0.6), transparent);"
          >
          </div>
          <div class="relative">
            <div
              class="w-12 h-12 rounded-xl mb-5 flex items-center justify-center"
              style="background: linear-gradient(135deg, rgba(251,191,36,0.15), rgba(245,158,11,0.1)); border: 1px solid rgba(251,191,36,0.2);"
            >
              <svg
                class="w-6 h-6 text-business-warning"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"
                ></path>
              </svg>
            </div>
            <h3
              class="text-lg font-semibold text-business-text mb-2 group-hover:text-business-warning transition-colors"
            >
              Magazyn
            </h3>
            <p class="text-sm text-business-text-dim leading-relaxed">
              Pełne zarządzanie stanami magazynowymi, przyjęciami, wydaniami i
              inwentaryzacją. Zawsze wiesz co masz na stanie.
            </p>
            <div
              class="mt-4 flex items-center gap-1.5 text-xs text-business-warning opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-2 group-hover:translate-x-0"
            >
              <span>Otwórz moduł</span>
              <svg
                class="w-3.5 h-3.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </div>
        </a>

        <!-- Finanse -->
        <a
          href="/finanse"
          class="module-card group relative overflow-hidden rounded-2xl p-6 transition-all duration-300 cursor-pointer"
          style="background: rgba(10,10,10,0.8); border: 1px solid rgba(255,255,255,0.06);"
        >
          <div
            class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            style="background: linear-gradient(135deg, rgba(34,197,94,0.05) 0%, transparent 60%);"
          >
          </div>
          <div
            class="absolute top-0 left-0 right-0 h-px opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            style="background: linear-gradient(90deg, transparent, rgba(34,197,94,0.6), transparent);"
          >
          </div>
          <div class="relative">
            <div
              class="w-12 h-12 rounded-xl mb-5 flex items-center justify-center"
              style="background: linear-gradient(135deg, rgba(34,197,94,0.15), rgba(16,185,129,0.1)); border: 1px solid rgba(34,197,94,0.2);"
            >
              <svg
                class="w-6 h-6 text-green-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <h3
              class="text-lg font-semibold text-business-text mb-2 group-hover:text-green-400 transition-colors"
            >
              Finanse
            </h3>
            <p class="text-sm text-business-text-dim leading-relaxed">
              Śledzenie przepływów finansowych, budżetowanie, faktury VAT i
              raporty finansowe w czasie rzeczywistym.
            </p>
            <div
              class="mt-4 flex items-center gap-1.5 text-xs text-green-400 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-2 group-hover:translate-x-0"
            >
              <span>Otwórz moduł</span>
              <svg
                class="w-3.5 h-3.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"></path>
